# Frontend API configuration (copy to .env and adjust)

# Leave empty if your Vite dev server can reach backend via relative paths.
VITE_API_BASE_URL=http://localhost:8787

# Backend endpoints (default guesses; update to match your backend)
VITE_BLOGS_ENDPOINT=/api/blogs
VITE_GALLERY_ENDPOINT=/api/gallery
VITE_LOGIN_ENDPOINT=/api/auth/login

